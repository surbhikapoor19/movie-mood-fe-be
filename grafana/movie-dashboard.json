        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "chat_request_duration_seconds{quantile=\"0.9\"}",
          "legendFormat": "p90",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" },
        "overrides": []
      }
    },
    {
